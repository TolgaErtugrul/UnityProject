using UnityEngine;
using TMPro;
using UnityEngine.UI;
using UnityEngine.SceneManagement;

public class PlayerController : MonoBehaviour
{
    [SerializeField] private float moveSpeed = 7.0f;
    [SerializeField] private int score = 0; // Puanımızı tutacak değişken
    [SerializeField] private TextMeshProUGUI scoreText; // 2. Ekranda görünecek yazı objesi
    [SerializeField] private int health = 3; // Başlangıç canı
    [SerializeField] private TextMeshProUGUI healthText; // Can yazısı
    [SerializeField] private Image damageImage; // Kırmızı ekran resmi
    [SerializeField] private float flashSpeed = 5f; // Efektin kaybolma hızı
    [SerializeField] private Color flashColor = new Color(1f, 0f, 0f, 0.3f);
    [SerializeField] private GameObject gameOverPanel;
    [SerializeField] private Spawner spawner; // Spawner'a erişim

    [Header("Ses Efektleri")]
    [SerializeField] private AudioClip coinSound;
    [SerializeField] private AudioClip damageSound;
    
    private Rigidbody rb;
    private bool isGrounded;
    private bool isDamaged = false;
    private AudioSource audioSource;

    private void Start()
    {
        UpdateScoreUI();
        audioSource = GetComponent<AudioSource>();
    }

    private void OnTriggerEnter(Collider other)
    {
        // Altın Toplama
        if (other.gameObject.CompareTag("Coin"))
        {
            score++;
            UpdateScoreUI();
            audioSource.PlayOneShot(coinSound); // Altın alınca
            Destroy(other.gameObject);
        }
        
        // Engele Çarpma
        if (other.gameObject.CompareTag("Obstacle"))
        {
            TakeDamage();
            audioSource.PlayOneShot(damageSound); // Hasar alınca
            Destroy(other.gameObject); // Bize çarpan engeli yok edelim
        }
    }

    void UpdateScoreUI()
    {
        scoreText.text = "Puan: " + score;
        
        // Profesyonel Dokunuş: Her 5 puanda bir zorluğu artır
        if (score > 0 && score % 5 == 0)
        {
            spawner.IncreaseDifficulty(0.2f);
        }
    }

    void Update()
    {
        // 1. Girişleri Al (Eksen Sistemi)
        float horizontalInput = Input.GetAxis("Horizontal"); // A/D veya Sağ/Sol
        float verticalInput = Input.GetAxis("Vertical");     // W/S veya Yukarı/Aşağı

        // 2. Hareket Yönünü Hesapla
        Vector3 movement = new Vector3(horizontalInput, 0, verticalInput);

        // 3. Objeyi Hareket Ettir
        // transform.Translate yerine daha akıcı bir yöntem:
        transform.Translate(movement * moveSpeed * Time.deltaTime);

        // Zıplama (Dünkü kodumuz)
        if (Input.GetKeyDown(KeyCode.Space) && isGrounded)
        {
            rb.AddForce(Vector3.up * jumpForce, ForceMode.Impulse);
            isGrounded = false;
        }

        // Hasar alındıysa ekranı kırmızı yap, sonra yavaşça şeffaf hale getir
        if (isDamaged)
        {
            damageImage.color = flashColor;
        }
        else
        {
            damageImage.color = Color.Lerp(damageImage.color, Color.clear, flashSpeed * Time.deltaTime);
        }
        isDamaged = false; // Her karede sıfırla
    }

    private void OnCollisionEnter(Collision collision)
    {
        if (collision.gameObject.CompareTag("Ground"))
        {
            isGrounded = true;
        }
    }

    private void TakeDamage()
    {
        isDamaged = true; // Efekti tetikle
            health--;
            UpdateUI();
    
            if (health <= 0) GameOver();
    }

    private void GameOver()
    {
        gameOverPanel.SetActive(true); // Paneli göster
        Time.timeScale = 0f; // Zamanı durdur
    }

    void UpdateUI()
    {
        healthText.text = "Can: " + health.ToString();
    }

    public void RestartGame()
    {
        Time.timeScale = 1f; // Zamanı geri akıt
        // Mevcut sahneyi yeniden yükle
        SceneManager.LoadScene(SceneManager.GetActiveScene().name);
    }
}
